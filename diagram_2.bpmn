    <bpmn:textAnnotation id="TextAnnotation_1ughexi">
      <bpmn:text>как заявка может быть создана в системе 1 и при этом по телефону/почте
если сначала оформляется заявка по телефону/почте а потом уже эта заявка переносится в систему 1, то кто ее переносит? автоматически или отдельный сотрудник руками</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0ui1hfp" associationDirection="None" sourceRef="Activity_0up25xl" targetRef="TextAnnotation_1ughexi" />
    <bpmn:textAnnotation id="TextAnnotation_17t2ew6">
      <bpmn:text>каким образом вызывается логистика, как логистика снабжается информацией куда когда вести оборудование</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0b9mn6d" associationDirection="None" sourceRef="Activity_1372mx0" targetRef="TextAnnotation_17t2ew6" />
    <bpmn:textAnnotation id="TextAnnotation_105drg5">
      <bpmn:text>что делать если нет оборудования</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0jaxlj2" associationDirection="None" sourceRef="Activity_10w67nv" targetRef="TextAnnotation_105drg5" />
  </bpmn:collaboration>
